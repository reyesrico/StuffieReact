# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git
#
# IMPORTANT: All variables must use VITE_ prefix (Vite requirement)
# Access in code: import.meta.env.VITE_*

# Cloudinary Configuration
VITE_CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key_here
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# Codehooks Configuration
VITE_CODEHOOKS_API_KEY=your_codehooks_api_key_here
VITE_CODEHOOKS_SERVER_URL=https://stuffie-2u0v.api.codehooks.io/dev/

# Facebook Configuration
VITE_FB_APP_ID=your_facebook_app_id_here

# Spotify Configuration
# Get credentials from https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Azure Maps Configuration (for Map component)
VITE_AZURE_MAPS_KEY=your_azure_maps_key_here

# Google Custom Search (Image Search in AddProduct — 100 free queries/day)
# 1. Create a Custom Search Engine at https://programmablesearchengine.google.com
# 2. Enable "Image search" and set it to search the entire web
# 3. Create an API key at https://console.cloud.google.com → Custom Search API
VITE_GOOGLE_SEARCH_API_KEY=your_google_api_key_here
VITE_GOOGLE_SEARCH_CX=your_custom_search_engine_id_here

# Unsplash API (fallback when Google quota is exceeded)
# Register at https://unsplash.com/developers → create an app → copy Access Key
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Support email shown in the AI chat "stuck" banner.
# If omitted, the app will use the first admin user's email from the database.
VITE_SUPPORT_EMAIL=

# Web Push (VAPID) Configuration
# Generate keys: cd backend && npx web-push generate-vapid-keys
# Private key + subject are stored ONLY in Codehooks env vars (never in frontend)
# Set on backend: npx coho setenv VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:you@example.com
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Google OAuth — get from console.cloud.google.com → Credentials → OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Apple OAuth — get from developer.apple.com → Certificates → Identifiers → Services ID
VITE_APPLE_CLIENT_ID=your_apple_services_id_here
VITE_APPLE_REDIRECT_URI=https://yourdomain.com
